# 즉시 새로고침 토큰: /api/refresh?token=<값> 을 열면 1시간 캐시를 기다리지
# 않고 Notion 최신 내용을 바로 반영합니다. 아무 랜덤 문자열이나 가능
# (예: `openssl rand -hex 16`). Vercel 환경변수에도 같은 값을 등록하세요.
REVALIDATE_TOKEN=

# Notion CMS (콘텐츠는 Notion "TUPA CMS" 페이지에서 관리)
# notion.so/my-integrations 에서 Internal Integration 생성 후 키를 넣고,
# TUPA CMS 페이지 ⋯ → Connections 에서 해당 integration을 연결하세요.
# 키가 없으면 사이트는 코드에 내장된 데이터로 동작합니다 (절대 깨지지 않음).
NOTION_API_KEY=

# 데이터베이스 ID (기본값이 코드에 있으므로 보통 비워둬도 됩니다.
# 워크스페이스를 옮겨 DB를 다시 만들 때만 덮어쓰세요.)
# NOTION_DB_MEMBERS=7aa78084bb144fe394ea80c27cef7d79
# NOTION_DB_PUBLICATIONS=2f424be849424013ab8dd84de56e92a8
# NOTION_DB_NEWS=bf42bc1321bf401ba5f1d4b96685c091
# NOTION_DB_RESEARCH_AREAS=6df65f389bdd45dd8d38550c6cf72766
# NOTION_DB_PROJECTS=4aa6450de72244ddb77e960f0e8972c9
# NOTION_DB_OPENINGS=e98c6f76086b4792a449acb6a570e006
# NOTION_DB_GALLERY=4ba8a240a18a403b84e024621b22beb4
# NOTION_DB_SETTINGS=3d0ceee3eddb48af932d09a4181bf363
# NOTION_DB_PAGE_COPY=99dfb9e8a6b149d0a83df8b56243798a
