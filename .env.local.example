# 즉시 새로고침 토큰: /api/refresh?token=<값> 을 열면 1시간 캐시를 기다리지
# 않고 Notion 최신 내용을 바로 반영합니다. 아무 랜덤 문자열이나 가능
# (예: `openssl rand -hex 16`). Vercel 환경변수에도 같은 값을 등록하세요.
REVALIDATE_TOKEN=

# Notion CMS (콘텐츠는 Notion "TUPA CMS" 페이지에서 관리)
# notion.so/my-integrations 에서 Internal Integration 생성 후 키를 넣고,
# TUPA CMS 페이지 ⋯ → Connections 에서 해당 integration을 연결하세요.
# 키가 없으면 사이트는 코드에 내장된 데이터로 동작합니다 (절대 깨지지 않음).
NOTION_API_KEY=

# 데이터베이스 ID (기본값이 코드에 있으므로 보통 비워둬도 됩니다.
# 워크스페이스를 옮겨 DB를 다시 만들 때만 덮어쓰세요.)
# NOTION_DB_MEMBERS=6fb5f228be9082d5ab5a810c9aa1f4f4
# NOTION_DB_PUBLICATIONS=d705f228be9083dba5cd81b084ec6ee2
# NOTION_DB_NEWS=3695f228be9083fc9bef0184dbaf522c
# NOTION_DB_RESEARCH_AREAS=f425f228be9083dcb32b01ec402abe91
# NOTION_DB_PROJECTS=bcb5f228be9082dd883701d1089d531c
# NOTION_DB_OPENINGS=38a5f228be9083c9a1e981fcbba9dbe5
# NOTION_DB_GALLERY=8205f228be9082dc958f81858126381e
# NOTION_DB_SETTINGS=e6b5f228be90833dbda401293b3bf369
# NOTION_DB_FAQS=b965f228be9082e3861e01bbc7861d2a
# NOTION_DB_PAGE_COPY=5145f228be90830d959201dd82fd6e88
# NOTION_DB_JOURNEYS=a305f228be908270809f01c47f60e729
